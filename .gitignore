# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# platform config (contains API keys)
data/*.json

# one-off migration script outputs (plan/log JSON files)
scripts/.out/

# OEE SQLite database
oee.db
oee.db-wal
oee.db-shm

# claude code (local/personal — shared settings.json IS committed)
.claude/settings.local.json
CLAUDE.local.md

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
